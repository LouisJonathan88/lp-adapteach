{
  "version": "1.0.0",
  "source": "./index.html",
  "type": "module",
  "name": "adapteach",
  "description": "A React project for the AdapTeach platform using the Shadcn UI library",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
